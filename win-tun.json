{
  "log": {
    "disabled": false,
    "level": "info",
    "timestamp": true
  },
  "experimental": {
    "cache_file": {
      "enabled": true,
      "store_fakeip": false,
      "store_rdrc": true,
      "path": "tun-cache-rule-v1.db"
    },
    "clash_api": {
      "external_controller": "[::]:9191"
    }
  },
  "dns": {
    "servers": [
      {
        "tag": "dns_proxy",
        "type": "https",
        "server": "1.1.1.1",
        "detour": "🌐Proxy",
        "connect_timeout": "5s"
      },
      {
        "tag": "dns_direct",
        "type": "https",
        "server": "223.5.5.5",
        "connect_timeout": "5s"
      },
      {
        "tag": "dns_fakeip",
        "type": "fakeip",
        "inet4_range": "198.18.0.0/15",
        "inet6_range": "fc00::/18"
      }
    ],
    "rules": [
      {
        "query_type": [
          "HTTPS",
          "SVCB",
          "PTR"
        ],
        "action": "reject"
      },
      {
        "domain_suffix": [
          ".tiktok.com"
        ],
        "rule_set": [
          "geosite-tiktok",
          "geosite-linkedin",
          "geosite-linkedin-cn"
        ],
        "server": "dns_fakeip"
      },
      {
        "domain": [
          "captive.oneoh.cloud",
          "captive.apple.com",
          "nmcheck.gnome.org",
          "www.msftconnecttest.com",
          "connectivitycheck.gstatic.com"
        ],
        "rule_set": [
          "geoip-cn",
          "geosite-cn",
          "geosite-apple",
          "geosite-microsoft-cn",
          "geosite-private"
        ],
        "strategy": "prefer_ipv4",
        "server": "dns_direct"
      },
      {
        "query_type": [
          "A",
          "AAAA",
          "CNAME"
        ],
        "server": "dns_fakeip",
        "strategy": "prefer_ipv4"
      }
    ],
    "final": "dns_proxy",
    "strategy": "prefer_ipv4"
  },
  "inbounds": [
    {
      "tag": "tun-in",
      "type": "tun",
      "address": [
        "172.19.0.1/30",
        "fdfe:dcba:9876::1/126"
      ],
      "platform": {
        "http_proxy": {
          "enabled": true,
          "server": "::",
          "server_port": 2134
        }
      },
      "mtu": 9000,
      "stack": "gvisor",
      "auto_route": true,
      "strict_route": true,
      "sniff": true,
      "sniff_override_destination": true,
      "route_exclude_address": [
        "10.0.0.0/8",
        "100.64.0.0/10",
        "127.0.0.0/8",
        "169.254.0.0/16",
        "172.16.0.0/12",
        "192.0.0.0/24",
        "192.168.0.0/16",
        "224.0.0.0/4",
        "240.0.0.0/4",
        "255.255.255.255/32",
        "fe80::/10",
        "fc00::/7",
        "ff01::/16",
        "ff02::/16",
        "ff03::/16",
        "ff04::/16",
        "ff05::/16",
        "240e::/20"
      ]
    },
    {
      "tag": "mixed",
      "type": "mixed",
      "listen": "::",
      "listen_port": 2134,
      "reuse_addr": true,
      "tcp_fast_open": true,
      "set_system_proxy": false
    }
  ],
  "outbounds": [
    {
      "tag": "🎯Direct",
      "type": "direct",
      "domain_resolver": "dns_direct"
    },
    {
      "tag": "🌐Proxy",
      "type": "selector",
      "outbounds": [
        "⚡UrlTest"
      ],
      "interrupt_exist_connections": true
    },
    {
      "tag": "🚀LowLatency",
      "type": "urltest",
      "outbounds": [],
      "url": "http://www.gstatic.com/generate_204",
      "interval": "3m",
      "tolerance": 50,
      "interrupt_exist_connections": true
    },
    {
      "tag": "⚡UrlTest",
      "type": "urltest",
      "outbounds": [],
      "url": "http://www.gstatic.com/generate_204",
      "interval": "3m",
      "tolerance": 50,
      "interrupt_exist_connections": true
    }
  ],
  "route": {
    "default_domain_resolver": "dns_direct",
    "auto_detect_interface": true,
    "final": "🌐Proxy",
    "rules": [
      {
        "inbound": "mixed-in",
        "action": "sniff",
        "sniffer": [
          "http",
          "tls",
          "quic",
          "dns",
          "ssh",
          "bittorrent"
        ],
        "timeout": "200ms"
      },
      {
        "protocol": "dns",
        "action": "hijack-dns"
      },
      {
        "action": "resolve",
        "strategy": "prefer_ipv4"
      },
      {
        "source_ip_cidr": [
          "224.0.0.0/3",
          "ff00::/8"
        ],
        "ip_cidr": [
          "224.0.0.0/3",
          "ff00::/8"
        ],
        "action": "reject"
      },
      {
        "protocol": "quic",
        "action": "reject"
      },
      {
        "protocol": [
          "bittorrent",
          "ssh",
          "stun"
        ],
        "outbound": "🎯Direct"
      },
      {
        "clash_mode": "Global",
        "outbound": "🌐Proxy"
      },
      {
        "type": "logical",
        "mode": "or",
        "rules": [
          {
            "clash_mode": "Direct"
          },
          {
            "ip_is_private": true
          }
        ],
        "outbound": "🎯Direct"
      },
      {
        "domain": [
          "direct-tag.oneoh.cloud"
        ],
        "ip_cidr": [
          "45.221.114.55/32",
          "103.149.93.9/32"
        ],
        "outbound": "🎯Direct"
      },
      {
        "rule_set": [
          "hdy-domain",
          "hdy-port",
          "hdy-pname"
        ],
        "outbound": "🎯Direct"
      },
      {
        "rule_set": [
          "geoip-cn",
          "geosite-cn"
        ],
        "outbound": "🎯Direct"
      },
      {
        "rule_set": [
          "geoip-google",
          "geosite-google",
          "geosite-github"
        ],
        "outbound": "🚀LowLatency"
      },
      {
        "rule_set": [
          "geosite-apple",
          "geosite-microsoft-cn",
          "geosite-private"
        ],
        "outbound": "🎯Direct"
      },
      {
        "rule_set": [
          "geosite-steam",
          "geosite-category-games",
          "geosite-dmm"
        ],
        "outbound": "🎯Direct"
      },
      {
        "rule_set": "geosite-bilibili",
        "outbound": "🎯Direct"
      },
      {
        "rule_set": [
          "geoip-telegram",
          "geosite-telegram"
        ],
        "outbound": "🌐Proxy"
      },
      {
        "rule_set": [
          "geosite-tiktok",
          "geosite-linkedin",
          "geosite-linkedin-cn",
          "geosite-geolocation-!cn"
        ],
        "outbound": "🌐Proxy"
      }
    ],
    "rule_set": [
      {
        "tag": "geoip-cn",
        "type": "remote",
        "format": "binary",
        "url": "https://jsdelivr.oneoh.cloud/gh/MetaCubeX/meta-rules-dat@sing/geo/geoip/cn.srs"
      },
      {
        "tag": "geosite-geolocation-cn",
